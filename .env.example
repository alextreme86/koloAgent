# Copy this to .env and fill in the real values
# On the Pi: cp .env.example .env && nano .env

GEMINI_API_KEY=your_gemini_api_key_here
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT=your_telegram_chat_id_here
CAM_PASS=your_camera_password_here

# Dashboard access token (optional, leave blank to disable auth)
KOLO_DASH_TOKEN=kolo2026
